# Copy this file to .env and fill in your values

# Required Settings
BOT_TOKEN=your_discord_bot_token_here

# Recording Configuration
RECORDING_MODE=single_user
# Options: single_user, all_users, whitelist
TARGET_USER_ID=123456789012345678
# For single_user mode: the user ID to record
# For whitelist mode: comma-separated list of user IDs (e.g., 123456789,987654321)

# Channel Filters (optional)
ALLOWED_CHANNELS=
# Comma-separated channel IDs. Leave empty to record in all channels
BLOCKED_CHANNELS=
# Comma-separated channel IDs to never record in

# Audio Settings
AUTO_CONVERT=true
# Convert recordings to WAV automatically (true/false)
AUDIO_FORMAT=wav
# Output format: wav, mp3, or pcm
MAX_RECORDING_MINUTES=60
# Maximum recording length per session (0 = unlimited)

# Advanced Settings
SILENCE_TIMEOUT=5000
# Milliseconds of silence before stopping individual recordings
CREATE_SEPARATE_FILES=true
# Create separate files per speaking session (true) or one continuous file (false)
LOG_LEVEL=info
# Logging verbosity: debug, info, warn, error